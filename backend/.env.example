# Application settings for Personalized Learning System
APP_NAME=Personalized Learning System
APP_VERSION=1.0.0
DEBUG=true

# SQLite database URL (relative path from backend/ directory)
DATABASE_URL=sqlite:///./learning_system.db

# CORS: comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
