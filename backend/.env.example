# Application settings for Personalized Learning System
APP_NAME=Personalized Learning System
APP_VERSION=1.0.0
DEBUG=true

# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=personalized_learning_system
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personalized_learning_system

# CORS: comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
